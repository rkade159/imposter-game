    "svelte": "^5.19.0",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/status-bar": "^8.0.2"
  }
}
